# === ОБЯЗАТЕЛЬНО ===
# Сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHARS

# === СЕРВЕР ===
PORT=5000
HOST=0.0.0.0
FLASK_ENV=production
JWT_EXPIRY=43200
SECURE_COOKIES=False
MAX_UPLOAD_MB=16

# === TELEGRAM BOT (необязательно) ===
# Создать бота через @BotFather, вставить токен ниже
TELEGRAM_BOT_TOKEN=

# === БАЗА ДАННЫХ (будущее) ===
